 var mediaPlayer = MediaPlayer()

        play.setOnClickListener {

            if(play.text=="start"){
                mediaPlayer.reset()
                mediaPlayer = MediaPlayer.create(this, R.raw.file)
                mediaPlayer.prepare()
                mediaPlayer.start()
                play.text="stop"
            } else if (play.text=="stop")
                mediaPlayer.stop()
            play.text="start"
        }
