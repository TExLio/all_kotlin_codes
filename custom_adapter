class customAdapter (context: Context?, private val objects: Array<out String?>, private val image: Array<out Int?>) : ArrayAdapter<String>(context, R.layout.item, objects) {
    
    override fun getView(position: Int, convertView: View?, parent: ViewGroup?): View{
        
        val l: LayoutInflater = LayoutInflater.from(context)
        val customView: View = l.inflate(R.layout.item, parent, false)
        
        customView.textView.text = objects!![position]
        customView.imageView.setImageResource(image!![position])
        
        return customView
    }
}
