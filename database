class myDataBase(context: Context) : SQLiteOpenHelper(context, DATABASE_NAME, null, DATABASE_VERSION){

    fun addProducts(productName: String, name: String, productQuantity: String, quantity : Int, productId : String, id: Int){
        val db = this.writableDatabase
        val values = ContentValues()
        values.put(productName, name)
        values.put(productQuantity, quantity)
        values.put(productId, id)

        db.insert(DATABASE_TABLE_NAME, null, values)
        db.close()
    }

    fun deleteProducts(productName: String){
        val db = writableDatabase
        db.execSQL("delete from $DATABASE_TABLE_NAME where $NAME = $productName")
    }

    fun findProduct(productName: String) : Array<String>{

        var dbString: Array<String>
        val db = writableDatabase
        val query = "select * from $DATABASE_TABLE_NAME where $NAME = $productName"

        val c = db.rawQuery(query, null)

        dbString = Array(c.count) {""}

        c.moveToFirst()

        while(!c.isAfterLast){
            for (i in dbString.indices){

                if (
                c.getString(c.getColumnIndexOrThrow(ID)) != null &&
                c.getString(c.getColumnIndexOrThrow(NAME)) != null &&
                c.getString(c.getColumnIndexOrThrow(QUANTITY)) != null
                ) {
                    dbString[i] += c.getString(c.getColumnIndexOrThrow(ID)) + "_" +
                                   c.getString(c.getColumnIndexOrThrow(NAME)) + "_" +
                                   c.getString(c.getColumnIndexOrThrow(QUANTITY)) + "_"
                }
                c.moveToNext()
            }
        }
        c.close()
        return dbString
    }
    fun databaseToString(productName: String) : Array<String>{

        var dbString: Array<String>
        val db = writableDatabase
        val query = "select * from $DATABASE_TABLE_NAME where 1"

        val c = db.rawQuery(query, null)

        dbString = Array(c.count) {""}

        c.moveToFirst()

        while(!c.isAfterLast){
            for (i in dbString.indices){

                if (
                    c.getString(c.getColumnIndexOrThrow(ID)) != null &&
                    c.getString(c.getColumnIndexOrThrow(NAME)) != null &&
                    c.getString(c.getColumnIndexOrThrow(QUANTITY)) != null
                ) {
                    dbString[i] += c.getString(c.getColumnIndexOrThrow(ID)) + "_" +
                            c.getString(c.getColumnIndexOrThrow(NAME)) + "_" +
                            c.getString(c.getColumnIndexOrThrow(QUANTITY)) + "_"
                }
                c.moveToNext()
            }
        }
        c.close()
        return dbString
    }

    override fun onCreate(db: SQLiteDatabase?) {
        db?.execSQL(DATABASE_CREATE)
    }

    override fun onUpgrade(db: SQLiteDatabase?, oldVersion: Int, newVersion: Int) {
        db?.execSQL("DROP TABLE IF EXISTS $DATABASE_TABLE_NAME")
    }

    companion object{
        val ID = "id"
        val NAME = "name"
        val QUANTITY = "quantity"

        val DATABASE_TABLE_NAME = "products"
        private val DATABASE_NAME = "data.db"
        private val DATABASE_VERSION = 1
        private val DATABASE_CREATE = "create table $DATABASE_TABLE_NAME (" +
                "$ID INTEGER PRIMARY KEY AUTOINCREMENT, " +
                "$NAME TEXT NOT NULL, " +
                "$QUANTITY INTEGER);"
    }
}
