import android.content.ContentValues
import android.content.Context
import android.database.Cursor
import android.database.sqlite.SQLiteDatabase
import android.database.sqlite.SQLiteOpenHelper

class MyDatabase(context: Context) :
    SQLiteOpenHelper(context, DATABASE_NAME, null, DATABASE_VERSION) {

    companion object {

        const val KEY_ID = "_ID"
        const val P_NAME = "NAME"
        const val P_QUANTITY = "QUANTITY"
        const val DATABASE_TABLE_NAME = "products"

        private const val DATABASE_NAME = "data.db"
        private const val DATABASE_VERSION = 1

        private const val DATABASE_CREATE =
            "CREATE TABLE $DATABASE_TABLE_NAME (" +
                    "$KEY_ID INTEGER PRIMARY KEY AUTOINCREMENT, " +
                    "$P_NAME TEXT NOT NULL, " +
                    "$P_QUANTITY INTEGER);"
    }

    override fun onCreate(db: SQLiteDatabase?) {
        db?.execSQL(DATABASE_CREATE)
    }

    override fun onUpgrade(db: SQLiteDatabase?, oldVersion: Int, newVersion: Int) {
        db?.execSQL("DROP TABLE IF EXISTS $DATABASE_TABLE_NAME")
        onCreate(db)
    }

    fun addProduct(name: String, quantity: Int) {
        val db = this.writableDatabase
        val values = ContentValues()

        values.put(P_NAME, name)
        values.put(P_QUANTITY, quantity)

        db.insert(DATABASE_TABLE_NAME, null, values)
        db.close()
    }

    fun deleteProduct(name: String) {
        val db = this.writableDatabase
        db.delete(DATABASE_TABLE_NAME, "$P_NAME=?", arrayOf(name))
        db.close()
    }

    fun findProduct(productname: String): Array<String> {

        var dbString: Array<String>

        val db: SQLiteDatabase = writableDatabase

        val query =
            "SELECT * FROM $DATABASE_TABLE_NAME WHERE $P_NAME = \"$productname\""

        val c: Cursor = db.rawQuery(query, null)

        dbString = Array(c.count) { "" }

        c.moveToFirst()

        while (!c.isAfterLast) {

            for (i in dbString.indices) {

                if (
                    c.getString(c.getColumnIndexOrThrow(KEY_ID)) != null &&
                    c.getString(c.getColumnIndexOrThrow(P_NAME)) != null &&
                    c.getString(c.getColumnIndexOrThrow(P_QUANTITY)) != null
                ) {

                    dbString[i] =
                        c.getString(c.getColumnIndexOrThrow(KEY_ID)) + "_ " +
                                c.getString(c.getColumnIndexOrThrow(P_NAME)) + " " +
                                c.getString(c.getColumnIndexOrThrow(P_QUANTITY))
                }

                c.moveToNext()
            }
        }

        c.close()

        return dbString
    }

    fun databaseToString(): Array<String> {

        var dbString: Array<String>

        val db: SQLiteDatabase = writableDatabase

        val query = "SELECT * FROM $DATABASE_TABLE_NAME WHERE 1"

        val c: Cursor = db.rawQuery(query, null)

        dbString = Array(c.count) { "" }

        c.moveToFirst()

        while (!c.isAfterLast) {

            for (i in dbString.indices) {

                if (
                    c.getString(c.getColumnIndexOrThrow(KEY_ID)) != null &&
                    c.getString(c.getColumnIndexOrThrow(P_NAME)) != null &&
                    c.getString(c.getColumnIndexOrThrow(P_QUANTITY)) != null
                ) {

                    dbString[i] =
                        c.getString(c.getColumnIndexOrThrow(KEY_ID)) + "_ " +
                                c.getString(c.getColumnIndexOrThrow(P_NAME)) + " " +
                                c.getString(c.getColumnIndexOrThrow(P_QUANTITY))
                }

                c.moveToNext()
            }
        }

        c.close()

        return dbString
    }
}
